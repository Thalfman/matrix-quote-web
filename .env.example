# Copy to .env (gitignored) and fill in real values.

# Admin auth — required in production, no defaults.
ADMIN_PASSWORD=change-me
ADMIN_JWT_SECRET=replace-with-32-plus-random-bytes

# Admin JWT expiry in hours. Default matches backend/app/deps.py.
ADMIN_TOKEN_EXPIRY_HOURS=12

# Where master Parquet, upload log, and model artifacts live.
# Local dev: "." (files land in ./data/master and ./models).
# Railway: "/data" (matches the mounted volume in railway.json).
DATA_DIR=.

# HTTP port. Railway injects this automatically; only set locally.
PORT=8000

# CORS origins for local frontend dev. In prod the frontend is served by
# FastAPI from the same origin so this is only needed during development.
CORS_ALLOW_ORIGINS=http://localhost:5173
